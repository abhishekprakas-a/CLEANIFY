# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Water Tank Cleaning Service"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (MongoDB / Mongoose)
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/waterTankCleaning
MONGODB_DB_NAME=waterTankCleaning

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
# Use a long random string. Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
AUTH_COOKIE_NAME=wtcs_token
AUTH_REFRESH_COOKIE_NAME=wtcs_refresh
# Refresh-token (session) lifetime in days; the "remember me" variant is longer.
JWT_REFRESH_EXPIRES_IN_DAYS=7
JWT_REFRESH_REMEMBER_DAYS=30
# How long a password-reset link stays valid (minutes).
PASSWORD_RESET_EXPIRES_MINUTES=30

# ---------------------------------------------------------------------------
# File Storage (Cloudflare R2 — S3-compatible API)
# ---------------------------------------------------------------------------
# Find the account id in the Cloudflare dashboard. The endpoint is either set
# explicitly or derived as https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=replace_me
R2_ENDPOINT=https://replace_me.r2.cloudflarestorage.com
# R2 always uses the "auto" region.
R2_REGION=auto
R2_BUCKET=water-tank-cleaning
# Create an R2 API token (S3 Auth) for these credentials.
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
# Public base URL: the bucket's r2.dev dev domain or your custom domain.
R2_PUBLIC_BASE_URL=https://pub-replace_me.r2.dev
R2_PRESIGNED_EXPIRES_SECONDS=300

# ---------------------------------------------------------------------------
# Web Push (PWA notifications) — optional. Generate with:
#   npx web-push generate-vapid-keys
# Push is disabled until both keys are set.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@watertank.local

# ---------------------------------------------------------------------------
# Seeding (initial admin account created by `npm run seed`)
# ---------------------------------------------------------------------------
SEED_ADMIN_NAME="Super Admin"
SEED_ADMIN_EMAIL=admin@watertank.local
SEED_ADMIN_PHONE=9999999999
SEED_ADMIN_PASSWORD=ChangeMe@123
